# ─── Google AI ───────────────────────────────────────────────────────────────
# Used by Gemini (interpretation, refinement, summarization)
# and Lyria (full-song audio generation).
# Generate a key at: https://aistudio.google.com/apikey
VITE_GOOGLE_API_KEY=your_google_ai_api_key_here

# Gemini model for structured intelligence operations.
# Default: gemini-3-flash-preview
VITE_GEMINI_MODEL=gemini-3-flash-preview

# Lyria model for full-song audio generation.
# Default: lyria-3-pro-preview
VITE_LYRIA_MODEL=lyria-3-pro-preview

# Nano Banana image model for automatic project cover generation.
# Default: gemini-2.5-flash-image
VITE_NANO_BANANA_MODEL=gemini-2.5-flash-image


# ─── Spotify ─────────────────────────────────────────────────────────────────
# PKCE OAuth — only the client ID is used on the frontend. Do not put your
# client secret in any VITE_* variable; it would be visible in the browser.
# Manage apps at: https://developer.spotify.com/dashboard
#
# Required Spotify app settings:
#   - Redirect URIs: add http://127.0.0.1:5173/spotify-callback (local dev)
#   - APIs used: Web API
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/spotify-callback


# ─── Firebase ────────────────────────────────────────────────────────────────
# Optional but recommended for accounts, profiles, and Firestore-backed sync.
# Create a Firebase web app and copy these from Project Settings > General.
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_optional
